# SCHF Core - Environment Configuration
# Copie para .env e ajuste os valores

# Application
APP_NAME=SCHF
APP_ENV=production
APP_KEY=base64:generate_with_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost:9080

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=schf
DB_USERNAME=schf
DB_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379

# Frontend
FRONTEND_URL=http://localhost:9080

# Feature Flags
FEATURE_LEGACY_MODULE=false
FEATURE_MULTI_ORGANIZATION=true
FEATURE_SETUP_WIZARD=true
FEATURE_AUTO_UPDATES=false

# Updates
APP_UPDATE_REPO=ORG/schf-core

# MySQL Root
DB_ROOT_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=change_me_in_production
